# Required
GEMINI_API_KEY=your-gemini-api-key-here

# Admin panel password (visit /admin to access captured sessions)
ADMIN_KEY=change-me-to-a-strong-secret

# Slack incoming webhook URL for contact form notifications (optional)
SLACK_WEBHOOK_URL=

# Google Tag Manager container ID (optional, e.g. GTM-XXXXXXX)
GTM_ID=
